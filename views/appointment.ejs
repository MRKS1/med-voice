<%- include('partials/header') %>

<section class="section">
  <div class="container">
    <h2 class="page-title"><%= content.title %></h2>
    <p class="section-text centered-text"><%= content.intro %></p>

    <% if (message) { %>
      <div class="success-message">
        <%= message %>
      </div>
    <% } %>

    <div class="split-section appointment-layout">
      <form action="<%= content.formAction %>" method="POST">
        <label for="name"><%= content.labels.name %></label>
        <input type="text" id="name" name="name" required>

        <label for="email"><%= content.labels.email %></label>
        <input type="email" id="email" name="email" required>

        <label for="phone"><%= content.labels.phone %></label>
        <input type="text" id="phone" name="phone" required>

        <label for="date"><%= content.labels.date %></label>
        <input type="date" id="date" name="date" required>

        <label for="message"><%= content.labels.message %></label>
        <textarea id="message" name="message" rows="5"></textarea>

        <button type="submit"><%= content.submit %></button>
      </form>

      <div class="feature-list-box">
        <h3 class="section-subtitle"><%= content.asideTitle %></h3>
        <ul class="feature-list">
          <% content.asideItems.forEach((item) => { %>
            <li><%= item %></li>
          <% }) %>
        </ul>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
