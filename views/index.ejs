<%- include('partials/header') %>

<section class="hero hero-merge">
  <div class="container">
    <div class="hero-grid">
      <div class="hero-copy">
        <p class="eyebrow"><%= content.eyebrow %></p>
        <h2><%= content.heroTitle %></h2>
        <p class="hero-lead"><%= content.heroText %></p>
        <div class="hero-actions">
          <a href="<%= routes.contact %>" class="btn"><%= content.heroButton %></a>
          <a href="#features" class="btn btn-secondary"><%= content.heroSecondaryButton %></a>
        </div>
        <div class="trust-badges">
          <% content.trustBadges.forEach((badge) => { %>
            <span><%= badge %></span>
          <% }) %>
        </div>
      </div>
      <div class="hero-panel">
        <div class="panel-card">
          <p class="panel-label">AI</p>
          <h3><%= siteName %></h3>
          <p class="panel-text"><%= content.spotlightText %></p>
          <ul class="panel-list">
            <% content.spotlightPoints.forEach((point) => { %>
              <li><%= point %></li>
            <% }) %>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section" id="features">
  <div class="container">
    <h2 class="page-title"><%= content.benefitsTitle %></h2>
    <div class="cards">
      <% content.benefits.forEach((benefit) => { %>
        <div class="card">
          <h3><%= benefit.title %></h3>
          <p><%= benefit.text %></p>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<section class="section section-alt">
  <div class="container">
    <div class="split-section">
      <div>
        <h2 class="section-title"><%= content.complianceTitle %></h2>
        <p class="section-text"><%= content.complianceText %></p>
      </div>
      <div class="compliance-box">
        <p class="compliance-kicker">GDPR</p>
        <h3><%= content.complianceCardTitle %></h3>
        <p><%= content.complianceCardText %></p>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <h2 class="page-title"><%= content.stepsTitle %></h2>
    <div class="steps-grid">
      <% content.steps.forEach((step) => { %>
        <div class="step-card">
          <h3><%= step.title %></h3>
          <p><%= step.text %></p>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<section class="section cta-section">
  <div class="container">
    <div class="cta-box">
      <h2><%= content.ctaTitle %></h2>
      <p><%= content.ctaText %></p>
      <a href="<%= routes.contact %>" class="btn"><%= nav.contact %></a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
