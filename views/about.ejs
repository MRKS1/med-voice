<%- include('partials/header') %>

<section class="section">
  <div class="container">
    <h2 class="page-title"><%= content.title %></h2>
    <div class="split-section">
      <div class="content-box">
        <h3 class="section-subtitle"><%= content.introTitle %></h3>
        <% content.paragraphs.forEach((paragraph, index) => { %>
          <p><%= paragraph %></p>
          <% if (index < content.paragraphs.length - 1) { %>
            <br>
          <% } %>
        <% }) %>
      </div>
      <div class="feature-list-box">
        <h3 class="section-subtitle"><%= content.highlightsTitle %></h3>
        <ul class="feature-list">
          <% content.highlights.forEach((item) => { %>
            <li><%= item %></li>
          <% }) %>
        </ul>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
